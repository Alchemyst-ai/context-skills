async function* chunked<T>(it: AsyncIterable<T>, size: number): AsyncIterable<T[]> {
  let batch: T[] = [];
  for await (const item of it) {
    batch.push(item);
    if (batch.length >= size) {
      yield batch;
      batch = [];
    }
  }
  if (batch.length) yield batch;
}

async function ingestSync(): Promise<number> {
  const client = getClient();
  let total = 0;
  for await (const batch of chunked(iterSourceDocuments(), 100)) {
    await client.v1.context.add({ documents: batch });
    total += batch.length;
    console.log(`  added ${batch.length} (running total: ${total})`);
  }
  return total;
}

async function ingestAsync(): Promise<number> {
  const client = getClient();
  let total = 0;
  const jobIds: string[] = [];
  for await (const batch of chunked(iterSourceDocuments(), 1000)) {
    const resp = await client.v1.context.addAsync({ documents: batch });
    jobIds.push(resp.jobId);
    total += batch.length;
    console.log(`  queued ${batch.length} as job ${resp.jobId}`);
  }
  let pending = [...jobIds];
  while (pending.length) {
    await new Promise(r => setTimeout(r, 2000));
    const stillPending: string[] = [];
    for (const jid of pending) {
      const status = await client.v1.context.getAsyncStatus(jid);
      if (status.state === 'completed') {
        console.log(`  job ${jid}: done`);
      } else if (status.state === 'failed') {
        console.log(`  job ${jid}: FAILED — ${status.error ?? '?'}`);
      } else {
        stillPending.push(jid);
      }
    }
    pending = stillPending;
  }
  return total;
}

async function main(): Promise<void> {
  const mode = (process.argv[2] ?? '{{INGESTION_MODE}}') as 'sync' | 'async';
  console.log(`Ingesting in ${mode} mode...`);
  const n = mode === 'async' ? await ingestAsync() : await ingestSync();
  console.log(`Done. Ingested ${n} documents.`);
}

main().catch(err => {
  console.error(err);
  process.exit(1);
});
